  392:				;========================
  393:				; FIND FORK FOR O
  394:				; A fork = a cell where placing O creates
  395:				; TWO different lines each having 1 O and 2 empty
  396:				; We test each empty cell: place O, count threats, undo
  397:				; Use RAM 2EH as temp cell address, 2DH as threat counter
  398:				;========================
  399:	  0250			FIND_FORK_O:
  400:	  0250	C3		        CLR C
  401:	  0251	78 30		        MOV R0,#C1
  402:	  0253			FF_O_LOOP:
  403:	  0253	E6		        MOV A,@R0
  404:	  0254	70 16		        JNZ FF_O_NEXT
  405:				        ; cell is empty - temporarily place O
  406:	  0256	76 02		        MOV @R0,#02H
  407:	  0258	88 2E		        MOV 2EH,R0
  408:	  025A	12 02 9A	        LCALL COUNT_O_THREATS
  409:				        ; restore cell
  410:	  025D	A8 2E		        MOV R0,2EH
  411:	  025F	76 00		        MOV @R0,#00H
  412:				        ; if threats >= 2 this is a fork cell
  413:	  0261	E5 2D		        MOV A,2DH
  414:	  0263	B4 02 04	        CJNE A,#02H,FF_O_LT2
  415:				        ; found fork - set R0 to this cell
  416:	  0266	A8 2E		        MOV R0,2EH
  417:	  0268	D3		        SETB C
  418:	  0269	22		        RET
  419:	  026A			FF_O_LT2:
  420:	  026A	A8 2E		        MOV R0,2EH
  421:	  026C			FF_O_NEXT:
