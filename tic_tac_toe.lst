 1030:
 1031:				;========================
 1032:				; KEYPAD SCAN
 1033:				;
 1034:				; Physical keypad wiring (from Proteus schematic):
 1035:				;   Columns: C0=rightmost, C1, C2, C3=leftmost
 1036:				;   Rows:    R0=bottom(ON row), R1, R2, R3=top
 1037:				;
 1038:				;   C0 col: 7(R3), 4(R2), 1(R1), C(R0)
 1039:				;   C1 col: 8(R3), 5(R2), 2(R1), 0(R0)
 1040:				;   C2 col: 9(R3), 6(R2), 3(R1), =(R0)
 1041:				;   C3 col: /(R3), *(R2), -(R1), +(R0)
 1042:				;
 1043:				; P1.0=C0(col drive), P1.1=C1, P1.2=C2, P1.3=C3
 1044:				; P1.4=R0(row read),  P1.5=R1, P1.6=R2, P1.7=R3
 1045:				;========================
 1046:				; KEYPAD WIRING (verified from schematic):
 1047:				;   P1.0 = C0 = keypad row A  (top row:    /, 9, 8, 7)  <- DRIVE output
 1048:				;   P1.1 = C1 = keypad row B  (           *, 6, 5, 4)  <- DRIVE output
 1049:				;   P1.2 = C2 = keypad row C  (           -, 3, 2, 1)  <- DRIVE output
 1050:				;   P1.3 = C3 = keypad row D  (bottom row: +, =, 0, C)  <- DRIVE output
 1051:				;   P1.4 = R0 = keypad col1  (rightmost: 7, 4, 1, C)   <- READ input

ASEM-51 V1.3                                        Copyright (c) 2002 by W.W. Heinz                                         PAGE 20



 Line  I  Addr  Code            Source

 1052:				;   P1.5 = R1 = keypad col2  (           8, 5, 2, 0)   <- READ input
 1053:				;   P1.6 = R2 = keypad col3  (           9, 6, 3, =)   <- READ input
 1054:				;   P1.7 = R3 = keypad col4  (leftmost:  /, *, -, +)   <- READ input
 1055:				;
 1056:				; Scan: drive one row LOW, read columns P1.4-P1.7
 1057:				;   Drive P1.0 low -> P1=FEH  read: P1.4='7' P1.5='8' P1.6='9' P1.7='/'
 1058:				;   Drive P1.1 low -> P1=FDH  read: P1.4='4' P1.5='5' P1.6='6' P1.7='*'
 1059:				;   Drive P1.2 low -> P1=FBH  read: P1.4='1' P1.5='2' P1.6='3' P1.7='-'
 1060:				;   Drive P1.3 low -> P1=F7H  read: P1.4='C' P1.5='0' P1.6='=' P1.7='+'
 1061:				;========================
 1062:	  0605			KEY_SCAN:
 1063:				        ; --- Drive row A (P1.0) low ---
 1064:	  0605	75 90 FE	        MOV P1,#0FEH
 1065:	  0608	00		        NOP
 1066:	  0609	00		        NOP
 1067:	  060A	30 94 3F	        JNB P1.4,KEY_7
 1068:	  060D	30 95 42	        JNB P1.5,KEY_8
 1069:	  0610	30 96 45	        JNB P1.6,KEY_9
 1070:	  0613	30 97 48	        JNB P1.7,KEY_DIV
 1071:
 1072:				        ; --- Drive row B (P1.1) low ---
 1073:	  0616	75 90 FD	        MOV P1,#0FDH
 1074:	  0619	00		        NOP
 1075:	  061A	00		        NOP
 1076:	  061B	30 94 46	        JNB P1.4,KEY_4
 1077:	  061E	30 95 49	        JNB P1.5,KEY_5
 1078:	  0621	30 96 4C	        JNB P1.6,KEY_6
 1079:	  0624	30 97 4F	        JNB P1.7,KEY_MUL
 1080:
 1081:				        ; --- Drive row C (P1.2) low ---
 1082:	  0627	75 90 FB	        MOV P1,#0FBH
 1083:	  062A	00		        NOP
 1084:	  062B	00		        NOP
 1085:	  062C	30 94 4D	        JNB P1.4,KEY_1
 1086:	  062F	30 95 50	        JNB P1.5,KEY_2
 1087:	  0632	30 96 53	        JNB P1.6,KEY_3
 1088:	  0635	30 97 56	        JNB P1.7,KEY_SUB
 1089:
 1090:				        ; --- Drive row D (P1.3) low ---
 1091:	  0638	75 90 F7	        MOV P1,#0F7H
 1092:	  063B	00		        NOP
 1093:	  063C	00		        NOP
 1094:	  063D	30 94 54	        JNB P1.4,KEY_C
 1095:	  0640	30 95 57	        JNB P1.5,KEY_0
 1096:	  0643	30 96 5A	        JNB P1.6,KEY_EQ
 1097:	  0646	30 97 5D	        JNB P1.7,KEY_ADD
